{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data for both passengers and drivers",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string" },
        "name": { "type": "string" },
        "avatar": { "type": "string" },
        "role": { "type": "string", "enum": ["passenger", "driver", "admin"] },
        "phoneNumber": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "role"]
    },
    "Ride": {
      "title": "Ride",
      "description": "A ride request and active trip record",
      "type": "object",
      "properties": {
        "passengerId": { "type": "string" },
        "driverId": { "type": "string" },
        "status": { 
          "type": "string", 
          "enum": ["requested", "accepted", "started", "completed", "cancelled"] 
        },
        "pickupAddress": { "type": "string" },
        "pickupLat": { "type": "number" },
        "pickupLng": { "type": "number" },
        "destinationAddress": { "type": "string" },
        "destinationLat": { "type": "number" },
        "destinationLng": { "type": "number" },
        "price": { "type": "string" },
        "type": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["passengerId", "status"]
    },
    "Alert": {
      "title": "Alert",
      "description": "Security or emergency alert",
      "type": "object",
      "properties": {
        "rideId": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "resolved": { "type": "boolean" }
      }
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "rides/{rideId}": {
      "schema": "Ride",
      "description": "Ride records"
    },
    "alerts/{alertId}": {
      "schema": "Alert",
      "description": "Emergency alerts"
    }
  }
}
